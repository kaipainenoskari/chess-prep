# Optional: contact email for Chess.com API (recommended)
CHESS_COM_USER_AGENT=ChessPrepTool/1.0 (your-email@example.com)

# Backend analysis pipeline (PostgreSQL + Redis)
DATABASE_URL="postgresql://user:password@localhost:5432/chess_prep?schema=public"
REDIS_URL="redis://localhost:6379"

# Use trap-oriented expansion instead of fixed-depth expansion (Phase 4)
USE_TRAP_PIPELINE=true

# Logging for debugging (worker/API): trap pipeline and Lichess API
# LOG_TRAP_PIPELINE=1
# LOG_LICHESS=1
